# ── Namecheap API ──────────────────────────────────────────────────────────────
NAMECHEAP_API_USER=your_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_CLIENT_IP=your.public.ip.address
NAMECHEAP_SANDBOX=true          # Set to false for REAL purchases (costs money!)

# Your contact info for domain registrations
NAMECHEAP_REG_FIRST_NAME=John
NAMECHEAP_REG_LAST_NAME=Doe
NAMECHEAP_REG_ADDRESS=123 Main St
NAMECHEAP_REG_CITY=Tel Aviv
NAMECHEAP_REG_STATE=Tel Aviv
NAMECHEAP_REG_POSTAL=12345
NAMECHEAP_REG_COUNTRY=IL
NAMECHEAP_REG_PHONE=+972.501234567
NAMECHEAP_REG_EMAIL=you@example.com

# ── GoDaddy API (optional) ─────────────────────────────────────────────────────
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_ENVIRONMENT=test        # test or production

# ── Moz API (optional, free tier 10 req/month) ─────────────────────────────────
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# ── WHOIS XML API (500 free/month) ─────────────────────────────────────────────
WHOISXML_API_KEY=

# ── Email outreach via SendGrid (100 free/day) ────────────────────────────────
SENDGRID_API_KEY=
OUTREACH_FROM_EMAIL=you@yourdomain.com
OUTREACH_FROM_NAME=Your Name

# ── ExpiredDomains.net session ────────────────────────────────────────────────
# Log in at expireddomains.net in your browser, copy the "ef_session" cookie value
EXPIREDDOMAINS_SESSION_COOKIE=paste_session_cookie_here

# ── App settings ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/domains.db
SCAN_INTERVAL_HOURS=6
MAX_DOMAINS_PER_SCAN=500
MIN_SCORE_THRESHOLD=35
